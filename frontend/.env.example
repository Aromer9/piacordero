# Producción (Railway): origen del backend SIN /api al final.
# Ejemplo: https://piacordero-api.up.railway.app
# VITE_BACKEND_ORIGIN=

# Opcional: si solo defines la raíz del API (con /api), Vite deduce el mismo host para /uploads.
# Ejemplo: https://piacordero-api.up.railway.app/api
# VITE_API_ROOT=
