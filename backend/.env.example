# MongoDB - local o Atlas
# Local:
MONGODB_URI=mongodb://localhost:27017
# Atlas (reemplazar con tu connection string):
# MONGODB_URI=mongodb+srv://<usuario>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

MONGODB_DB=piacordero
UPLOAD_DIR=uploads
ALLOWED_ORIGINS=http://localhost:5173

# URL pública del backend (opcional). En Railway suele bastar con dejarla vacía y usar cabeceras del proxy.
# PUBLIC_BASE_URL=https://tu-api.up.railway.app

# Admin
ADMIN_PASSWORD=cambia-esta-contrasena
SECRET_KEY=genera-una-clave-secreta-larga-y-aleatoria
TOKEN_EXPIRE_HOURS=72
